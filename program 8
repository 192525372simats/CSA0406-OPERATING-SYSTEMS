#include <stdio.h>
#include <pthread.h>
void *fun1(void *arg){
    for(int i=1;i<=5;i++)
        printf("Thread1: %d\n",i);
    return NULL;
}
void *fun2(void *arg){
    for(int i=1;i<=5;i++)
        printf("Thread2: %d\n",i);
    return NULL;
}
int main() {
    pthread_t t1,t2;
    pthread_create(&t1,NULL,fun1,NULL);
    pthread_create(&t2,NULL,fun2,NULL);
    pthread_join(t1,NULL);
    pthread_join(t2,NULL);
    return 0;
}
